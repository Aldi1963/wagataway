# ─── API SERVER CONFIG ───────────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_URL=http://localhost:8080

# DATABASE
# Change wagateway_db with your actual database name
DATABASE_URL=postgresql://user:password@localhost:5432/wagateway_db

# SECURITY
# Generate a secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_secret_here

# WHATSAPP SESSION STORAGE
# Path relative to project root
SESSIONS_DIR=./wa-sessions

# ─── FRONTEND CONFIG ──────────────────────────────────────────────
# Build time variables (require rebuild if changed)
VITE_API_URL=/api
BASE_PATH=/

# ─── MAILING CONFIG (Optional) ───────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="WA Gateway <no-reply@domain.com>"

# ─── TELEGRAM NOTIFICATIONS (Optional) ───────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
